@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@implements IMovementEvents
@implements Chat.IMessageListener
@implements IRoleEvents
@namespace HNS

<root>
	<BlindScreen @ref="BlindScreen"></BlindScreen>
	<ChatBox @ref="ChatBox"></ChatBox>
	<StatusBar @ref="StatusBar"></StatusBar>
</root>

@code
{
	public BlindScreen BlindScreen { get; private set; }
	public ChatBox ChatBox { get; private set; }
	public StatusBar StatusBar { get; private set; }
	
    void IMovementEvents.OnFreeze(bool isFrozen) => BlindScreen.Toggle(isFrozen);
    void Chat.IMessageListener.OnUserMessage(string message, Connection sender) => ChatBox.AddMessage(new ChatBox.UserMessage(message, sender));
    void Chat.IMessageListener.OnSystemMessage(string message) => ChatBox.AddMessage(new ChatBox.SystemMessage(message));
	void IRoleEvents.OnRole(string role) => StatusBar.SetRole(role);

	protected override int BuildHash() => System.HashCode.Combine(ChatBox.GetHashCode());
}
